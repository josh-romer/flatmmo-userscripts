{
	"name": "flatmmo-userscripts-workspace",
	"workspaces": [
		"packages/lib/*",
		"packages/userscripts/*"
	],
	"scripts": {
		"postinstall": "bun2nix -o bun.nix",
		"build-static": "bun run packages/build/build.ts",
		"dev-static": "bun run packages/build/dev-watch.ts",
		"build-script": "bun run packages/build/build-userscript-cli.ts",
		"dev-script": "bun run packages/build/build-userscript-cli.ts --dev"
	},
	"devDependencies": {
		"@types/bun": "^1.3.4",
		"@violentmonkey/types": "^0.3.1",
		"flatmmo-types": "workspace:*",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"effect": "^3.19.14",
		"oxc-parser": "^0.108.0"
	}
}
